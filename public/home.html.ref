.large-full-width-cta__graphics > .row .col-4, .large-full-width-cta__graphics > .row .col-6, .large-full-width-cta__graphics > .row .col-12 { max-width: 100%; }
.large-full-width-cta__graphics > .row .col-4:nth-child(2n+1), .large-full-width-cta__graphics > .row .col-6:nth-child(2n+1), .large-full-width-cta__graphics > .row .col-12:nth-child(2n+1) { position: relative; top: 1.5rem; }
