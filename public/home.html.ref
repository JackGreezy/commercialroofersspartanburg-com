}
.large-full-width-cta__graphics > .row .col-4:nth-child(2n), .large-full-width-cta__graphics > .row .col-6:nth-child(2n), .large-full-width-cta__graphics > .row .col-12:nth-child(2n) { position: relative; bottom: 1.5rem; }
