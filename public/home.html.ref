.large-full-width-cta:has(.large-full-width-cta-swiper) .large-full-width-cta__wrapper__cta { padding-bottom: 3rem; }
.large-full-width-cta-swiper { height: 100%; }
.large-full-width-cta-swiper .swiper-slide { height: auto; align-self: stretch; }
.large-full-width-cta-swiper .swiper-slide > * { height: 100%; width: 100%; }
.large-full-width-cta.parallax { overflow: hidden; }
.large-full-width-cta.parallax .large-full-width-cta__background { background-attachment: fixed; background-position: center center; background-repeat: no-repeat; background-size: cover; height: 100%; }
@media (max-width: 991.98px) {
  .large-full-width-cta.parallax .large-full-width-cta__background { background-attachment: scroll !important; }
}
.large-full-width-cta.dark-brown-bg { background-color: rgb(53, 50, 47); }
.large-full-width-cta.dark-gray-bg { background-color: rgb(53, 50, 47); }
.large-full-width-cta.teal-bg { background-color: rgb(0, 116, 129); }
.large-full-width-cta.dark-green-bg { background-color: rgb(32, 90, 65); }
.large-full-width-cta__background { position: absolute; z-index: 1; left: 0px; top: 0px; width: 100%; height: 100%; background-size: cover; background-position: center center; transition: transform 0.1s ease-out, -webkit-transform 0.1s ease-out; }
.large-full-width-cta__background img { width: 100%; height: 100%; object-fit: cover; }
@media (min-width: 992px) {
  .large-full-width-cta { padding: 7rem 0px; }
  .large-full-width-cta:has(.large-full-width-cta-swiper) { padding-top: 0px; padding-bottom: 3rem; }
